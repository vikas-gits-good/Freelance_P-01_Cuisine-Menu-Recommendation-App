{
  "$schema": "https://backboard.railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "prod.Dockerfile",
    "watchPatterns": ["/Frontend/**"]
  },
  "deploy": {
    "startCommand": "caddy start --config /app/Caddyfile && redis-server --daemonize yes && exec uv run reflex run --env prod --backend-only",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "region": "asia-southeast1",
    "runtime": "V2",
    "limitOverride": {
      "containers": {
        "cpu": 4,
        "memoryBytes": 4000000000
      }
    }
  }
}
