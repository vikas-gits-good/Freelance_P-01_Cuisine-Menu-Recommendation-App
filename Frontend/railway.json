{
  "$schema": "https://backboard.railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "prod.Dockerfile",
    "watchPatterns": ["/Frontend/**"]
  },
  "deploy": {
    "startCommand": "parallel --ungroup --halt now,fail=1 ::: uv run reflex run --backend-only --env prod caddy run --config /etc/caddy/Caddyfile 2>&1",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "region": "asia-southeast1",
    "runtime": "V2",
    "limitOverride": {
      "containers": {
        "cpu": 4,
        "memoryBytes": 4000000000
      }
    }
  }
}
